JWT_SECRET=change-me-to-a-long-random-string
ADMIN_SECRET=change-me-too

FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000

# Service-account JSON as a single line. Generate at console.cloud.google.com.
# Share each tenant's Drive folder + Sheet with the SA's client_email.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Per-tenant Drive folders + Sheet name. Add tenants here without redeploying code.
TENANTS_JSON={"patko":{"filled_forms_folder_id":"1rUUpGi3K-bngZR0g-ObfEGROD1J0UEut","application_data_folder_id":"REPLACE_ME","submissions_sheet_name":"IMM5645 Submissions"}}

